# Anthropic Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Kimi (Moonshot) API key — get from https://platform.moonshot.ai
KIMI_API_KEY=sk-...
KIMI_MODEL=moonshot-v1-8k
KIMI_API_URL=https://api.moonshot.ai/v1/chat/completions

# GitHub token used to clone the pushed repo for analysis (needed for private repos).
# In GitHub Actions, pass ${{ secrets.GITHUB_TOKEN }}.
GITHUB_TOKEN=ghp_...

# Secret used to validate GitHub webhook payloads (set same value in GitHub repo settings)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Shared secret that verifies the /webhook/results callback from the generated
# GitHub Actions workflow. Set the SAME value as the target repo's
# ARIA_CALLBACK_TOKEN secret. (ARIA_CALLBACK_URL is NOT set here — it is ARIA's
# own public URL and lives only as a GitHub secret in the target repo.)
ARIA_CALLBACK_TOKEN=your_callback_token_here

# Discord incoming webhook URL for test reports
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Ngrok auth token for local tunnel — get from https://dashboard.ngrok.com
# When set, ARIA opens a tunnel at startup and uses its URL for dashboard links.
NGROK_AUTHTOKEN=your_ngrok_token_here

# Optional: override the public base URL used for the dashboard links in Discord
# (e.g. a deployed domain). Takes precedence over the ngrok tunnel URL.
PUBLIC_BASE_URL=

# ClickUp API token — get from https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=pk_...

# ClickUp list ID where bug tickets will be filed
CLICKUP_LIST_ID=your_list_id_here

# MongoDB connection URI (local or Atlas)
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name
MONGODB_DB_NAME=aria

# Base URL of the frontend app under test
BASE_URL_FRONTEND=http://localhost:3000

# Base URL of the API under test
BASE_URL_API=http://localhost:8080

# Run Playwright in headless mode (True for CI, False for local debugging)
PLAYWRIGHT_HEADLESS=True
